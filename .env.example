# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Connection string for your PostgreSQL database (e.g., Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/pantry_db?schema=public"

# -----------------------------------------------------------------------------
# AWS Cognito Configuration
# -----------------------------------------------------------------------------
# These are prefixed with NEXT_PUBLIC_ so they can be exposed to the client-side
# AWS Amplify SDK for authentication. This is safe because Cognito Client IDs are public.
NEXT_PUBLIC_AWS_REGION="us-east-1"
NEXT_PUBLIC_AWS_USER_POOL_ID="us-east-1_xxxxxxxxx"
NEXT_PUBLIC_AWS_USER_POOL_WEB_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# Cron Job Configuration
# -----------------------------------------------------------------------------
# Secret key used to verify that incoming cron requests are legitimate.
# This MUST match the Authorization header sent by your cron provider (e.g., cron-job.org).
CRON_SECRET="my-super-secret-cron-key-2026"
